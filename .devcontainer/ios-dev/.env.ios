# iOS Development Configuration

# Capacitor Configuration
CAPACITOR_APP_ID=com.colortimer.app
CAPACITOR_APP_NAME=Color Timer
CAPACITOR_WEB_DIR=public

# Development Settings
IOS_DEVELOPMENT_TEAM=
IOS_BUNDLE_ID=com.colortimer.app

# Build Settings
BUILD_CONFIGURATION=Debug
CODE_SIGN_IDENTITY=iPhone Developer

# Deployment Settings
DEPLOYMENT_TARGET=13.0
TARGETED_DEVICE_FAMILY=1,2

# Features
ENABLE_HAPTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_BACKGROUND_MODES=false

# Assets
ICON_SOURCE=resources/icon.png
SPLASH_SOURCE=resources/splash.png
